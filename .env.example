# ============================================
# ComplyGuard AI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your real values.
# Variables prefixed with VITE_ are injected into the frontend bundle at build time.

# --- CRITICAL (app will not load without these) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_key_here

# --- SERVER-ONLY SECRETS (set in Vercel env vars) ---
GEMINI_API_KEY=your_gemini_key_here

# --- OPTIONAL (app loads, but specific features disable gracefully) ---
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id_here
VITE_PAYPAL_ENVIRONMENT=production
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- SERVER-ONLY SECRETS (set in Vercel env vars, NEVER in VITE_ prefix) ---
# These are used by /api/* serverless functions only.
# RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# PAYPAL_CLIENT_SECRET=your_paypal_secret_here
